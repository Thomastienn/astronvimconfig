				"        let m = (l + r) / 2;",
				"        self.build(a, 2 * v, l, m);",
				"        self.build(a, 2 * v + 1, m + 1, r);",
				"        self.t[v] = self.t[2 * v] + self.t[2 * v + 1];",
				"    }",
				"    fn update(&mut self, i: usize, val: i64) {",
