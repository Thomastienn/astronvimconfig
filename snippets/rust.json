				"                if v == p { continue; }",
				"                if vis[v] {",
				"                    let mut cycle = vec![v];",
				"                    let mut x = u;",
				"                    while x != v { cycle.push(x); x = par[x]; }",
				"                    cycle.reverse();",
				"                    return cycle;",
				"                }",
				"                vis[v] = true;",
				"                par[v] = u;",
				"                stk.push((v, u, 0));",
				"            } else {",
				"                stk.pop();",
				"            }",
				"        }",
				"    }",
				"    Vec::new()",
