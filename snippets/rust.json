				"        let m = (l + r) / 2;",
				"        if i <= m { self.upd(i, val, 2 * v, l, m); }",
				"        else { self.upd(i, val, 2 * v + 1, m + 1, r); }",
				"        self.t[v] = self.t[2 * v] + self.t[2 * v + 1];",
